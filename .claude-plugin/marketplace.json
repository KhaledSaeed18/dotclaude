{
  "name": "dotclaude",
  "owner": {
    "name": "Khaled Saeed",
    "email": "khaled18saeed@gmail.com"
  },
  "description": "Claude Code skills, agents, commands, and hooks from the dotclaude registry, bundled as installable plugins.",
  "plugins": [
    {
      "name": "engineering",
      "source": "./",
      "description": "Engineering workflow skills and review agents: planning, test-driven development, systematic debugging, code review, completion verification, and performance work.",
      "author": {
        "name": "Khaled Saeed"
      },
      "homepage": "https://github.com/KhaledSaeed18/dotclaude",
      "repository": "https://github.com/KhaledSaeed18/dotclaude",
      "license": "MIT",
      "category": "development",
      "keywords": [
        "workflow",
        "tdd",
        "debugging",
        "code-review",
        "planning"
      ],
      "strict": false,
      "skills": [
        "./skills/engineering/adversarial-reviewer",
        "./skills/engineering/code-review-response",
        "./skills/engineering/executing-plans",
        "./skills/engineering/explain-codebase",
        "./skills/engineering/grill-with-docs",
        "./skills/engineering/parallel-agents",
        "./skills/engineering/performance-optimization",
        "./skills/engineering/systematic-debugging",
        "./skills/engineering/test-driven-development",
        "./skills/engineering/verify-completion",
        "./skills/engineering/writing-plans"
      ],
      "agents": [
        "./agents/engineering/architect-reviewer/AGENT.md",
        "./agents/engineering/code-reviewer/AGENT.md",
        "./agents/engineering/debugger/AGENT.md",
        "./agents/engineering/error-detective/AGENT.md",
        "./agents/engineering/performance-engineer/AGENT.md"
      ],
      "commands": [
        "./.claude-plugin/commands/explain-code.md"
      ]
    },
    {
      "name": "security",
      "source": "./",
      "description": "Security review toolkit: OWASP-aligned code review, dependency and secret auditing skills, a security-auditor agent, and a full-codebase /security-audit command.",
      "author": {
        "name": "Khaled Saeed"
      },
      "homepage": "https://github.com/KhaledSaeed18/dotclaude",
      "repository": "https://github.com/KhaledSaeed18/dotclaude",
      "license": "MIT",
      "category": "security",
      "keywords": [
        "owasp",
        "audit",
        "secrets",
        "dependencies"
      ],
      "strict": false,
      "skills": [
        "./skills/security/dependency-audit",
        "./skills/security/owasp-security",
        "./skills/security/secret-scan"
      ],
      "agents": [
        "./agents/security/security-auditor/AGENT.md"
      ],
      "commands": [
        "./.claude-plugin/commands/security-audit.md"
      ]
    },
    {
      "name": "security-hooks",
      "source": "./",
      "description": "Deterministic guardrails, active immediately after install: a compound-command deny list, sensitive-file protection, and prompt-injection screening.",
      "author": {
        "name": "Khaled Saeed"
      },
      "homepage": "https://github.com/KhaledSaeed18/dotclaude",
      "repository": "https://github.com/KhaledSaeed18/dotclaude",
      "license": "MIT",
      "category": "security",
      "keywords": [
        "hooks",
        "guardrails",
        "deny-list",
        "prompt-injection"
      ],
      "strict": false,
      "hooks": {
        "PreToolUse": [
          {
            "matcher": "Bash",
            "hooks": [
              {
                "type": "command",
                "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/security/smart-approve/smart-approve.mjs\""
              }
            ]
          },
          {
            "matcher": ".*",
            "hooks": [
              {
                "type": "command",
                "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/security/sensitive-file-guard/sensitive-file-guard.mjs\""
              }
            ]
          }
        ],
        "UserPromptSubmit": [
          {
            "hooks": [
              {
                "type": "command",
                "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/security/injection-guard/injection-guard.mjs\""
              }
            ]
          }
        ]
      }
    },
    {
      "name": "git",
      "source": "./",
      "description": "Version-control skills for the whole branch lifecycle: committing, worktrees, merge conflicts, undo/recovery, PR descriptions, changelogs, releases, and branch cleanup.",
      "author": {
        "name": "Khaled Saeed"
      },
      "homepage": "https://github.com/KhaledSaeed18/dotclaude",
      "repository": "https://github.com/KhaledSaeed18/dotclaude",
      "license": "MIT",
      "category": "version-control",
      "keywords": [
        "git",
        "commits",
        "worktrees",
        "releases",
        "pull-requests"
      ],
      "strict": false,
      "skills": [
        "./skills/version-control/changelog",
        "./skills/version-control/finish-branch",
        "./skills/version-control/git-commit",
        "./skills/version-control/git-undo",
        "./skills/version-control/git-worktrees",
        "./skills/version-control/gitignore",
        "./skills/version-control/merge-conflict",
        "./skills/version-control/pr-description",
        "./skills/version-control/release-tag"
      ],
      "commands": [
        "./.claude-plugin/commands/clean-branches.md"
      ]
    },
    {
      "name": "productivity",
      "source": "./",
      "description": "Session productivity skills: collaborative brainstorming, plan stress-testing, session handoff documents, and a /prime command that loads project context.",
      "author": {
        "name": "Khaled Saeed"
      },
      "homepage": "https://github.com/KhaledSaeed18/dotclaude",
      "repository": "https://github.com/KhaledSaeed18/dotclaude",
      "license": "MIT",
      "category": "productivity",
      "keywords": [
        "brainstorming",
        "handoff",
        "context",
        "planning"
      ],
      "strict": false,
      "skills": [
        "./skills/productivity/brainstorming",
        "./skills/productivity/grill-me",
        "./skills/productivity/handoff"
      ],
      "commands": [
        "./.claude-plugin/commands/prime.md"
      ]
    },
    {
      "name": "testing",
      "source": "./",
      "description": "Testing toolkit: browser-based end-to-end verification with Playwright and a /write-tests command that generates a suite matching project conventions.",
      "author": {
        "name": "Khaled Saeed"
      },
      "homepage": "https://github.com/KhaledSaeed18/dotclaude",
      "repository": "https://github.com/KhaledSaeed18/dotclaude",
      "license": "MIT",
      "category": "testing",
      "keywords": [
        "testing",
        "playwright",
        "e2e",
        "unit-tests"
      ],
      "strict": false,
      "skills": [
        "./skills/testing/webapp-testing"
      ],
      "commands": [
        "./.claude-plugin/commands/write-tests.md"
      ]
    },
    {
      "name": "research",
      "source": "./",
      "description": "A deep-research subagent for multi-source investigation with citations: comparisons, fact-checking, and sourced writeups.",
      "author": {
        "name": "Khaled Saeed"
      },
      "homepage": "https://github.com/KhaledSaeed18/dotclaude",
      "repository": "https://github.com/KhaledSaeed18/dotclaude",
      "license": "MIT",
      "category": "research",
      "keywords": [
        "research",
        "citations",
        "web"
      ],
      "strict": false,
      "agents": [
        "./agents/research/deep-research/AGENT.md"
      ]
    },
    {
      "name": "tool-call-logger",
      "source": "./",
      "description": "Observability hook that appends one sanitized JSON line per tool call to a local log, with secret redaction and payload truncation.",
      "author": {
        "name": "Khaled Saeed"
      },
      "homepage": "https://github.com/KhaledSaeed18/dotclaude",
      "repository": "https://github.com/KhaledSaeed18/dotclaude",
      "license": "MIT",
      "category": "observability",
      "keywords": [
        "logging",
        "observability",
        "audit"
      ],
      "strict": false,
      "hooks": {
        "PostToolUse": [
          {
            "matcher": "*",
            "hooks": [
              {
                "type": "command",
                "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/observability/tool-call-logger/log-tool-calls.mjs\""
              }
            ]
          }
        ]
      }
    }
  ]
}
