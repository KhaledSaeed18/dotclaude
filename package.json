{
  "name": "dotclaude",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Claude Code registry (skills, agents, commands, hooks) distributed via the shadcn GitHub registry.",
  "type": "module",
  "homepage": "https://github.com/KhaledSaeed18/dotclaude",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KhaledSaeed18/dotclaude.git"
  },
  "license": "MIT",
  "author": "Khaled Saeed",
  "packageManager": "pnpm@11.1.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "new": "tsx scripts/new.ts",
    "gen": "tsx scripts/gen.ts",
    "gen:check": "tsx scripts/gen.ts --check",
    "validate": "tsx scripts/validate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "^25",
    "gray-matter": "^4.0.3",
    "tsx": "^4",
    "typescript": "^6",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
